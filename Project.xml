<?xml version="1.0" encoding="utf-8"?>
<project>
	<!-- App -->

	<app title="ALE Psych" file="ALEPsych" main="core.Main" version="0.0.1" company="ALEPsychCrew"/>

	<window width="1280" height="720" fps="120" background="#000000" hardware="true" vsync="false"/>
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true"/>
	<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0"/>

	<icon path="art/icon16.png" size='16'/>
	<icon path="art/icon32.png" size='32'/>
	<icon path="art/icon64.png" size='64'/>
	<icon path="art/iconOG.png"/>

	<!-- ALE Defines -->

	<define name="ALLOW_HSCRIPT"/>

	<define name="ALLOW_CRASH_HANDLER"/>

	<define name="ALLOW_WINDOWS_API" if="windows cpp"/>
	
	<define name="ALLOW_MOBILE_API" if="mobile cpp"/>

	<!-- Assets -->

	<source path="source"/>
	<assets path="assets" embed="false"/>
	<assets path="defines" embed="false"/>

	<!-- Libraries -->

	<haxelib name="flixel"/>
	<haxelib name="flixel-addons"/>

	<haxelib name="sl-windows-api"/>

	<haxelib name="rulescript" if="ALLOW_HSCRIPT"/>

	<haxelib name="ale-ui"/>
	<haxelib name="ale-rulescript-wrapper" if="ALLOW_HSCRIPT"/>
	
	<!-- Flags -->

	<set name="BUILD_DIR" value="export/release"/>
	<set name="BUILD_DIR" value="export/32bit" if="32bits"/>

	<!-- haxeflag name="-dce" value="no"/-->

	<!-- Defines -->
	
	<set name="BUILD_DIR" value="export"/>
	<set name="SWF_VERSION" value="11.8"/>
	
	<define name="HX_WINDOWS" if="ALLOW_WINDOWS_API"/>

	<haxedef name="hscriptPos"/>

	<haxedef name='lime_disable_assets_version'/>	

	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN"/>
	<haxedef name="FLX_NO_HEALTH"/>
	<haxedef name="FLX_NO_DEBUG"/>

	<haxedef name="HXCPP_CHECK_POINTER" if="ALLOW_CRASH_HANDLER"/>
	<haxedef name="HXCPP_STACK_LINE" if="ALLOW_CRASH_HANDLER"/>
	<haxedef name="HXCPP_STACK_TRACE" if="ALLOW_CRASH_HANDLER"/>
	<haxedef name="HXCPP_GC_BIG_BLOCKS"/>
	<haxedef name="HXCPP_DEBUG_LINK"/>
	<haxedef name="HXCPP_CATCH_SEGV"/>

	<haxedef name='no-deprecation-warnings'/>
	<haxedef name="message.reporting" value="pretty"/>

	<!-- Android -->

	<config:android>
        <gradle-properties org.gradle.jvmargs="-Xmx2048m -XX:MaxMetaspaceSize=512m"/>
    </config:android>
		
	<architecture exclude="armv7" if="android"/>
	
	<config:android permission="android.permission.READ_EXTERNAL_STORAGE" if="android"/>
	<config:android permission="android.permission.WRITE_EXTERNAL_STORAGE" if="android"/>

	<config:android permission="android.permission.MANAGE_EXTERNAL_STORAGE"/>
	<config:android permission="android.permission.REQUEST_INSTALL_PACKAGES"/>

	<config:android permission="android.permission.INTERNET"/>
	<config:android permission="android.permission.ACCESS_NETWORK_STATE"/>

	<certificate path="key.keystore" password="aleenginepass" alias="ale-engine" alias-password="aleenginepass" if="android"/>
</project>
